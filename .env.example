# RevenueCat API keys
# Pass these via --dart-define when running or building:
#   flutter run --dart-define=REVENUECAT_APPLE_KEY=appl_xxx --dart-define=REVENUECAT_GOOGLE_KEY=goog_xxx
#   flutter build ios --dart-define=REVENUECAT_APPLE_KEY=appl_xxx

REVENUECAT_APPLE_KEY=appl_YOUR_KEY
REVENUECAT_GOOGLE_KEY=goog_YOUR_KEY
